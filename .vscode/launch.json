{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Wails Backend",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/build/bin/GraftikVideoPlayer.exe",
      "preLaunchTask": "wails-build-debug",
      "cwd": "${workspaceFolder}",
      "env": {},
      "args": [],
      "showLog": true
    },
    {
      "name": "Attach to Wails Dev",
      "type": "go",
      "request": "attach",
      "mode": "local",
      "processId": "${command:pickProcess}",
      "trace": "verbose"
    }
  ]
}
