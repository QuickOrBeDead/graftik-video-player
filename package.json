{
  "name": "graftik-video-player",
  "version": "0.0.7",
  "description": "Video Player application",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "QuickOrBeDead",
  "homepage": "https://github.com/QuickOrBeDead/graftik-video-player",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "posttest": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "test:ui": "npm rebuild better-sqlite3 && vitest --ui",
    "test:migrations": "npm rebuild better-sqlite3 && vitest run src/main/data/migrations.test.ts",
    "start": "electron-rebuild -f -w better-sqlite3 && electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build && electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "db:generate": "drizzle-kit generate",
    "db:push": "npm rebuild better-sqlite3 && drizzle-kit push && electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "db:studio": "npm rebuild better-sqlite3 && drizzle-kit studio && electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "prebuild": "npm run db:generate"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@imengyu/vue3-context-menu": "^1.5.4",
    "better-sqlite3": "^12.10.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "drizzle-orm": "^0.45.2",
    "electron-store": "^11.0.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "mousetrap": "^1.6.5",
    "uuid": "^14.0.0",
    "vue-router": "^5.0.7",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@rushstack/eslint-patch": "^1.16.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/http-cache-semantics": "^4.2.0",
    "@types/mousetrap": "^1.6.15",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.9.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "^4.1.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "drizzle-kit": "^0.31.10",
    "electron": "41.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-tsc": "^3.3.0"
  }
}
